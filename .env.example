# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...

# Parallel API key (required for research lookup, web search, and deep research
# via parallel-cli and the Parallel Chat API)
PARALLEL_API_KEY=...your-key-here...

# OpenRouter API key (optional, for AI image generation: schematics, figures,
# slides, infographics, and markitdown AI features)
OPENROUTER_API_KEY=sk-or-...your-key-here...

# NCBI credentials (optional, for higher-rate PubMed lookups in literature-review scripts)
# NCBI_API_KEY=...your-key-here...
# NCBI_EMAIL=you@example.com
